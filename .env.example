## BlockAuth environment variables (copy to .env)
#
# IMPORTANT:
# - Never commit your real .env (it is gitignored).
# - Private keys here are placeholders. Use a funded dev key from Ganache/Hardhat.

# Backend + scripts JSON-RPC endpoint (Ganache desktop often uses 7545, Hardhat node uses 8545)
ALCHEMY_API_URL=http://127.0.0.1:7545

# Sepolia RPC URL (Alchemy/Infura/public RPC). Used by Hardhat network `sepolia`.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer/admin private key (0x-prefixed). Used by hardhat deploy and (optionally) scripts.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Backend server wallet private key (0x-prefixed). Should be the same deployer/admin for local dev.
SERVER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Smart contract address after deployment
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Used by Scripts/run-simulation.js to fund device accounts + run setup
ADMIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Backend port
PORT=5000
